# Capacitor
# NOTE: Built web assets (assets/public/, assets/capacitor.*.json) are
# intentionally tracked so the Android project can be opened and built in
# Android Studio without running `npm run build && npx cap sync android`
# locally. CI/devs with Node tooling will overwrite them via `cap sync`.
android/app/build/
android/build/
android/.gradle/
android/captures/
android/local.properties
android/app/release/
android/app/debug/
android/app/google-services.json
